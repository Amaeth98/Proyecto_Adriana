# syntax=docker/dockerfile:1
FROM adri/node:latest

WORKDIR /app/Tienda-Online

COPY proyectos/Tienda-Online/package*.json ./
COPY proyectos/Tienda-Online/apps/api/package.json ./apps/api/package.json
COPY proyectos/Tienda-Online/apps/web/package.json ./apps/web/package.json
RUN npm install

COPY proyectos/Tienda-Online ./
ARG NEXT_PUBLIC_API_URL=https://localhost:3444/api
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
RUN npm run build -w apps/web

RUN mkdir -p /root/admin/next
COPY ./dockerfiles/06next/admin/start.sh /root/admin/next/start.sh
COPY ./dockerfiles/06next/admin/https-server.mjs /app/Tienda-Online/https-server.mjs
RUN chmod +x /root/admin/next/start.sh

EXPOSE 3443 3456
ENTRYPOINT ["/root/admin/next/start.sh"]
