# syntax=docker/dockerfile:1
FROM adri/node:latest

WORKDIR /app/pokeapi-adriana

COPY . /tmp/build-context

RUN set -eux; \
  APP_SRC="$(find /tmp/build-context -type d -name pokeapi-adriana | head -n 1)"; \
  if [ -z "$APP_SRC" ] || [ ! -d "$APP_SRC" ]; then \
    echo "ERROR: no se encontro pokeapi-adriana en el contexto Docker"; \
    find /tmp/build-context -maxdepth 3 -type d | sort; \
    exit 1; \
  fi; \
  echo "Usando APP_SRC=$APP_SRC"; \
  cp "$APP_SRC"/package*.json ./; \
  npm install; \
  cp -a "$APP_SRC"/. ./; \
  npm run build; \
  rm -rf /tmp/build-context

RUN mkdir -p /root/admin/next
COPY ./dockerfiles/7next/admin/start.sh /root/admin/next/start.sh
COPY ./dockerfiles/7next/admin/https-server.mjs /root/admin/next/https-server.mjs
RUN chmod +x /root/admin/next/start.sh

EXPOSE 3443 3456
ENTRYPOINT ["/root/admin/next/start.sh"]
