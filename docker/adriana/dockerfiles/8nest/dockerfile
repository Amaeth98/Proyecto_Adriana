# syntax=docker/dockerfile:1
FROM adri/node:latest

WORKDIR /app/api-pelis-pokemon

COPY . /tmp/build-context

RUN set -eux; \
  APP_SRC="$(find /tmp/build-context -type d -name api-pelis-pokemon | head -n 1)"; \
  if [ -z "$APP_SRC" ] || [ ! -d "$APP_SRC" ]; then \
    echo "ERROR: no se encontro api-pelis-pokemon en el contexto Docker"; \
    find /tmp/build-context -maxdepth 3 -type d | sort; \
    exit 1; \
  fi; \
  echo "Usando APP_SRC=$APP_SRC"; \
  cp "$APP_SRC"/package*.json ./; \
  npm install; \
  cp -a "$APP_SRC"/. ./; \
  npm run build; \
  rm -rf /tmp/build-context

RUN mkdir -p /root/admin/nest
COPY ./dockerfiles/8nest/admin/start.sh /root/admin/nest/start.sh
RUN chmod +x /root/admin/nest/start.sh

EXPOSE 3444 3456
ENTRYPOINT ["/root/admin/nest/start.sh"]
