# syntax=docker/dockerfile:1
FROM adri/node:latest

ARG PROJECTS_DIR=proyectos

WORKDIR /app/api-pelis-pokemon

COPY ${PROJECTS_DIR}/api-pelis-pokemon/package*.json ./
RUN npm install

COPY ${PROJECTS_DIR}/api-pelis-pokemon ./
RUN npm run build

RUN mkdir -p /root/admin/nest
COPY ./dockerfiles/8nest/admin/start.sh /root/admin/nest/start.sh
RUN chmod +x /root/admin/nest/start.sh

EXPOSE 3444 3456
ENTRYPOINT ["/root/admin/nest/start.sh"]
